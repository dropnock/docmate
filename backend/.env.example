# Either set DATABASE_URL directly, or leave it unset and configure the
# discrete POSTGRES_* vars below — they're assembled into a connection
# string safely (special characters in the password are handled correctly).
# DATABASE_URL=postgresql+asyncpg://docmate:docmate@localhost:5432/docmate
POSTGRES_USER=docmate
POSTGRES_PASSWORD=docmate
POSTGRES_DB=docmate
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

SECRET_KEY=change-me-in-production-use-32-chars-min
ACCESS_TOKEN_EXPIRE_MINUTES=480
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_ENDPOINT_URL=http://localhost:9000
# Only needed if the browser-facing S3/MinIO URL differs from AWS_ENDPOINT_URL
# above (e.g. behind a reverse proxy in production) — presigned URLs use this
# instead when set.
# AWS_PUBLIC_ENDPOINT_URL=https://s3.docmate.example.com
AWS_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# Comma-separated public base URLs for the digitizing portal — kept in sync
# with the docmate-de Keycloak client's redirect URIs on every startup.
DE_PORTAL_BASE_URLS=http://localhost:5173,http://localhost:80

# Temporary password assigned to demo/seed users by seed.py and seed_agents.py.
SEED_DEFAULT_PASSWORD=changeme123
