# Values used by docker-compose.yml for variable interpolation.
# Copy to .env and edit for your environment: cp .env.example .env

# ── Database ──────────────────────────────────────────────────────────────
POSTGRES_USER=docmate
POSTGRES_PASSWORD=docmate
POSTGRES_DB=docmate

# ── Keycloak ──────────────────────────────────────────────────────────────
KC_DB_NAME=keycloak
KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# ── Hostnames — must agree across nginx, Keycloak, and the backend ──────────
# The wildcard domain customer sub-realms are served under, e.g. docmate.local
# or docmate.example.com. Used by nginx's server_name regexes.
CUSTOMER_DOMAIN=docmate.local
# Hostname(s) nginx routes to the Digitizing Entity portal, space-separated.
DE_HOSTNAMES=www.docmate.local digitizing.docmate.local
# Hostname Keycloak itself is served under.
AUTH_HOSTNAME=auth.docmate.local
# Hostname nginx routes to MinIO/S3 — must be reachable from users' browsers,
# since presigned upload/view URLs point here (SigV4 signs the Host header,
# so this must match what the backend used to build the presigned URL — see
# S3_PUBLIC_URL below, which defaults to this value).
S3_HOSTNAME=s3.docmate.local

# Base URL of the customer portal WITHOUT subdomain — used to build each
# tenant's Keycloak redirect URIs (http://<realm>.<host>/*).
CUSTOMER_PORTAL_BASE_URL=https://docmate.local
# Comma-separated public base URLs for the digitizing portal — kept in sync
# with the docmate-de Keycloak client's redirect URIs on every backend startup.
DE_PORTAL_BASE_URLS=https://www.docmate.local,https://digitizing.docmate.local

# ── Object storage (MinIO/S3) ───────────────────────────────────────────────
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
# Defaults to https://<S3_HOSTNAME> — only set this if the browser-facing URL
# needs to differ (different scheme/port than the nginx-routed S3_HOSTNAME).
# S3_PUBLIC_URL=https://s3.docmate.example.com

# ── Secrets ───────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production

# Temporary password assigned to demo/seed users by seed.py and seed_agents.py.
SEED_DEFAULT_PASSWORD=changeme123
